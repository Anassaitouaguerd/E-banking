pipeline {
    agent any

   environment {
           MAVEN_HOME = tool 'Maven'
           DOCKER_IMAGE = 'zli9a/e-banking'
           DOCKER_TAG = "v${BUILD_NUMBER}"
           DOCKER_CREDENTIALS = '262777'
           SONAR_URL = 'http://sonarqube:9000'
           SONAR_TOKEN = credentials('sonar-token')
       }

       stages {
           stage('Environment Check') {
               steps {
                   sh '''
                       echo "Docker version:"
                       docker --version
                       echo "Docker Compose version:"
                       docker-compose --version
                       echo "Maven version:"
                       mvn --version
                       echo "Java version:"
                       java -version
                   '''
               }
           }

           stage('SonarQube Analysis') {
               steps {
                   script {
                       sh """
                           cd ebanking
                           mvn sonar:sonar \
                               -Dsonar.host.url=${SONAR_URL} \
                               -Dsonar.login=${SONAR_TOKEN} \
                               -Dsonar.projectKey=ebanking \
                               -Dsonar.projectName=ebanking
                       """
                   }
               }
           }
        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/Anassaitouaguerd/E-banking.git', branch: 'main'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    sh '''
                        cd ebanking
                        ${MAVEN_HOME}/bin/mvn sonar:sonar \
                            -Dsonar.host.url=http://localhost:9000 \
                            -Dsonar.token=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build') {
            steps {
                sh 'cd ebanking && ${MAVEN_HOME}/bin/mvn clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'cd ebanking && ${MAVEN_HOME}/bin/mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {

                    sh """
                        cd ebanking
                        docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} .
                        docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest
                    """
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    // Login to Docker Hub and push the image
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIALS}", passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                        sh """
                            echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin
                            docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                            docker logout
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            mail to: 'aitouaguerdanass@gmail.com',
                 subject: "Pipeline Success - E-Banking",
                 body: "Jenkins pipeline completed successfully!"
        }
        failure {
            mail to: 'aitouaguerdanass@gmail.com',
                 subject: "Pipeline Failure - E-Banking",
                 body: "Jenkins pipeline failed. Please check the logs."
        }
        always {
            // Clean up Docker images
            sh """
                docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG}
                docker rmi ${DOCKER_IMAGE}:latest
            """
        }
    }
}